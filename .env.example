# app
NEXT_PUBLIC_APP_URL = "http://localhost:3000"
NEXT_PUBLIC_APP_NAME = "ProductPic AI"
NEXT_PUBLIC_APP_DESCRIPTION = "AI ecommerce image generator for marketplace-ready product visuals"

# theme
NEXT_PUBLIC_THEME = "default"

# appearance
NEXT_PUBLIC_APPEARANCE = "system"

# database
DATABASE_PROVIDER = "postgresql"
DATABASE_URL = ""
DB_SINGLETON_ENABLED = "true"
DB_MAX_CONNECTIONS = "1"

# auth secret
# openssl rand -base64 32
AUTH_SECRET = ""
BETTER_AUTH_URL = "http://localhost:3000"
BETTER_AUTH_SECRET = ""

# optional: only needed when your local Node process must reach Google through a proxy
NODE_USE_ENV_PROXY = "1"
HTTP_PROXY = "http://127.0.0.1:7890"
HTTPS_PROXY = "http://127.0.0.1:7890"
NO_PROXY = "localhost,127.0.0.1,::1"

# ai
EVOLINK_API_KEY = ""
EVOLINK_BASE_URL = "https://api.evolink.ai"
